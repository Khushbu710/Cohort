{
  "name": "cohort",
  "private": true,
  "version": "0.1.0",
  "description": "Cohort — a protocol for confidential, dataset-agnostic industry surveys on Midnight.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @cohort/frontend dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "compact:build": "pnpm --filter @cohort/contracts compact:build",
    "devnet:up": "docker compose up -d",
    "devnet:down": "docker compose down"
  }
}
